{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "burhan:schemas/reference_comparison/v1",
  "title": "ReferenceComparisonReport",
  "description": "The validation-run comparison against a prior manual analysis (FR-1503). The reference is a comparison point, not ground truth: divergences start UNRESOLVED with no side presumed correct, and are classified only after investigation (Concept §15).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "study_id", "run_id", "reference_source", "comparisons", "summary"],
  "properties": {
    "schema_version": { "const": 1 },
    "study_id": { "type": "string" },
    "run_id": { "type": "string" },
    "reference_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "documents"],
      "properties": {
        "description": { "type": "string" },
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "caveats": { "type": "string", "description": "Known limitations of the reference (e.g., possible calculation or item-handling errors)." }
      }
    },
    "comparisons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["comparison_id", "domain", "metric", "status"],
        "properties": {
          "comparison_id": { "type": "string" },
          "domain": {
            "enum": ["n_chain", "cleaning_decision", "missing_treatment", "item_retention", "reliability", "convergent_validity", "discriminant_validity", "cmb", "fit", "respecification", "path", "effect", "hypothesis_verdict", "reporting_consistency"]
          },
          "metric": { "type": "string", "description": "What is being compared (e.g., 'final analytical N', 'loading R_TI.R9.std', 'H3a verdict')." },
          "reference_value": { "type": ["number", "string", "boolean", "null"] },
          "burhan_value": { "type": ["number", "string", "boolean", "null"] },
          "burhan_stat_id": { "type": "string", "description": "Results-store ID backing burhan_value, where applicable." },
          "delta": { "type": ["number", "null"] },
          "tolerance": { "type": ["number", "null"], "description": "From 12_DBA_VALIDATION_PROTOCOL.md tolerance table." },
          "status": { "enum": ["match", "divergent", "reference_missing", "burhan_only"] },
          "classification": {
            "enum": ["unresolved", "manual_weakness", "engine_or_policy_correction", "equivalent_defensible_choice"],
            "default": "unresolved",
            "description": "Set only after investigation; 'unresolved' until then."
          },
          "investigation": { "type": "string" },
          "resolution": { "type": "string", "description": "Action taken (policy edit, engine fix, reference correction noted) and re-run reference if any." }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "matches", "divergent", "unresolved"],
      "properties": {
        "total": { "type": "integer", "minimum": 1 },
        "matches": { "type": "integer", "minimum": 0 },
        "divergent": { "type": "integer", "minimum": 0 },
        "reference_missing": { "type": "integer", "minimum": 0 },
        "burhan_only": { "type": "integer", "minimum": 0 },
        "unresolved": { "type": "integer", "minimum": 0, "description": "Must be 0 before production use (Concept §15)." }
      }
    },
    "signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["researcher", "date"],
      "properties": {
        "researcher": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}
